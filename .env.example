PORT=8080
READ_TIMEOUT=300
WRITE_TIMEOUT=300
IDLE_TIMEOUT=120
DB_PATH=elimulocal.db
SESSION_SECRET=change-this-to-a-long-random-secret
SESSION_MAX_AGE=31536000
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE=524288000
APP_NAME=ElimuLocal
APP_ENV=production
TURSO_URL=libsql://your-database.turso.io
TURSO_TOKEN=your-turso-token
B2_KEY_ID=your-backblaze-key-id
B2_APP_KEY=your-backblaze-app-key
B2_BUCKET=elimulocal-uploads
B2_ENDPOINT=s3.us-west-004.backblaze.com